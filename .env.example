# ─────────────────────────────────────────────
# SRP — Environment Variables
# Copy this to .env.local and fill in real values.
# ─────────────────────────────────────────────

# Public — exposed to the browser. Anon key is safe to expose; RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose this. Used by admin client for privileged operations
# (e.g. inviting users, running migrations from a script).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL used for OAuth/OTP callbacks and absolute URL generation.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Sentry, PostHog, etc. (added in later phases)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
